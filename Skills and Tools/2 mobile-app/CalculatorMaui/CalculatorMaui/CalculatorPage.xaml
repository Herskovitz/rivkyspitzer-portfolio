<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CalculatorMaui.CalculatorPage"
             Title="Calculator">
    <ContentPage.Resources>
        <Style TargetType="Frame">
            <Setter Property="BorderColor"  Value="DarkSlateGrey"/>
            <Setter Property="BackgroundColor" Value="LightGrey"/>
            <Setter Property="Margin" Value="3"/>
        </Style>
    </ContentPage.Resources>
    <Grid ColumnDefinitions="*" RowDefinitions="*,*,4*">
        <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="*" Grid.Row="0" Grid.Column="0" Margin="3">
            <Frame Grid.Column="0">
                <Entry x:Name="txtFactor1"/>
            </Frame>
            <Frame Grid.Column="1">
                <Entry x:Name="txtOperator"/>
            </Frame>
            <Frame Grid.Column="2">
                <Entry x:Name="txtFactor2"/>
            </Frame>
            <Frame Grid.Column="3">
                <Entry x:Name="Answer"/>
            </Frame>
        </Grid>
        <Grid ColumnDefinitions="3*,*" RowDefinitions="*" Grid.Row="1" Grid.Column="0" Margin="3">
            <Button Text="C" Grid.Column="0" Grid.Row="0" Style="{StaticResource Key=result-button}"/>
            <Button Text="/" Grid.Column="1" Grid.Row="0"  Style="{StaticResource Key=operator-button}"/>
        </Grid>
        <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="*,*,*,*" Grid.Row="2" Grid.Column="0" Margin="3">
            <Button x:Name="btn7" Text="7" Grid.Column="0" Grid.Row="0"/>
            <Button x:Name="btn8" Text="8" Grid.Column="1" Grid.Row="0"/>
            <Button x:Name="btn9" Text="9" Grid.Column="2" Grid.Row="0"/>
            <Button x:Name="btn4" Text="4" Grid.Column="0" Grid.Row="1"/>
            <Button x:Name="btn5" Text="5" Grid.Column="1" Grid.Row="1"/>
            <Button x:Name="btn6" Text="6" Grid.Column="2" Grid.Row="1"/>
            <Button x:Name="btn1" Text="1" Grid.Column="0" Grid.Row="2"/>
            <Button x:Name="btn2" Text="2" Grid.Column="1" Grid.Row="2"/>
            <Button x:Name="btn3" Text="3" Grid.Column="2" Grid.Row="2"/>
            <Button x:Name="btnOperator" Text="-/+" Grid.Column="0" Grid.Row="3"/>
            <Button x:Name="btn0" Text="0" Grid.Column="1" Grid.Row="3"/>
            <Button x:Name="btnDecimal" Text="." Grid.Column="2" Grid.Row="3"/>
            <Button x:Name="btnMultiply" Text="*" Grid.Column="3" Grid.Row="0"  Style="{StaticResource Key=operator-button}"/>
            <Button x:Name="btnSubtract" Text="-" Grid.Column="3" Grid.Row="1"  Style="{StaticResource Key=operator-button}"/>
            <Button x:Name="btnAdd" Text="+" Grid.Column="3" Grid.Row="2"  Style="{StaticResource Key=operator-button}"/>
            <Button x:Name="btnEquals"  Text="=" Grid.Column="3" Grid.Row="3" Style="{StaticResource Key=result-button}"/>
        </Grid>
    </Grid>
</ContentPage>