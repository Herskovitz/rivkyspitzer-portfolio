<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="CalculatorMaui.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:CalculatorMaui"
    Title="CalculatorMaui">
    <TabBar>
        <ShellContent
        Title="Calculator"
        ContentTemplate="{DataTemplate local:CalculatorPage}"
        Route="CalculatorPage" />

        <ShellContent
       Title="History"
       ContentTemplate="{DataTemplate local:HistoryPage}"
       Route="HistoryPage" />
        </TabBar>
</Shell>
